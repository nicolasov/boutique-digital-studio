---
import { translations } from '../i18n/translations';

const year = new Date().getFullYear();
const t = translations.es;
---

<footer class="site-footer">
  <div class="section-shell footer-shell">
    <div class="footer-main">
      <div class="footer-identity">
        <p class="footer-logo">SOK</p>
        <p class="footer-brand">Boutique Digital Studio</p>
        <p class="footer-description" data-i18n="footerText">{t.footerText}</p>
      </div>
      <nav class="footer-nav" aria-label="Footer navigation">
        <a class="footer-link" href="#soluciones-digitales" data-i18n="navServices">{t.navServices}</a>
        <a class="footer-link" href="#work" data-i18n="navWork">{t.navWork}</a>
        <a class="footer-link" href="#proceso" data-i18n="navProcess">{t.navProcess}</a>
        <a class="footer-link" href="#contacto" data-i18n="navContact">{t.navContact}</a>
        <a class="footer-link" href="https://wa.me/5491132102111" target="_blank" rel="noreferrer" data-i18n="contactWhatsApp" data-whatsapp-link>{t.contactWhatsApp}</a>
        <a class="footer-link" href="https://cal.com/nicolas-oliva-velez-iehecs/hablemos-de-tu-proyecto" target="_blank" rel="noopener noreferrer" data-i18n="navCall">{t.navCall}</a>
      </nav>
    </div>
    <div class="footer-meta">
      <p>© {year} SOK. <span data-i18n="footerRights">{t.footerRights}</span></p>
      <p data-i18n="contactLocation">{t.contactLocation}</p>
    </div>
  </div>
</footer>
