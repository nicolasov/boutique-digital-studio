---
import { translations } from '../i18n/translations';

const year = new Date().getFullYear();
const t = translations.es;
---

<footer class="site-footer">
  <div class="section-shell flex h-full flex-col justify-between gap-8 py-10 sm:py-14">
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
      <div>
        <p class="display-font text-[clamp(3rem,8vw,8rem)] font-bold leading-[0.9] tracking-[-0.065em] text-ink">
          SOK
        </p>
        <p class="mt-6 max-w-xl text-xl leading-8 text-ink/80" data-i18n="footerText">{t.footerText}</p>
      </div>
      <nav class="grid gap-3 text-lg font-semibold text-ink sm:grid-cols-2 lg:justify-self-end" aria-label="Footer navigation">
        <a class="footer-link" href="#soluciones-digitales" data-i18n="navServices">{t.navServices}</a>
        <a class="footer-link" href="#beneficios" data-i18n="navBenefits">{t.navBenefits}</a>
        <a class="footer-link" href="#work" data-i18n="navWork">{t.navWork}</a>
        <a class="footer-link" href="#proceso" data-i18n="navProcess">{t.navProcess}</a>
        <a class="footer-link" href="#contacto" data-i18n="navContact">{t.navContact}</a>
        <a class="footer-link" href="https://wa.me/5491132102111" target="_blank" rel="noreferrer" data-i18n="contactWhatsApp" data-whatsapp-link>{t.contactWhatsApp}</a>
        <a class="footer-link" href="https://cal.com/nicolas-oliva-velez-iehecs/hablemos-de-tu-proyecto" data-i18n="navCall" data-cal-open>{t.navCall}</a>
      </nav>
    </div>
    <div class="flex flex-col gap-3 border-t border-ink/12 pt-5 text-sm text-ink/70 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} SOK. <span data-i18n="footerRights">{t.footerRights}</span></p>
      <p data-i18n="contactLocation">{t.contactLocation}</p>
    </div>
  </div>
</footer>
