---
import { translations } from '../i18n/translations';

const steps = [
  ['processOneTitle', 'processOneText'],
  ['processTwoTitle', 'processTwoText'],
  ['processThreeTitle', 'processThreeText'],
  ['processFourTitle', 'processFourText'],
  ['processFiveTitle', 'processFiveText'],
  ['processSixTitle', 'processSixText'],
];

const t = translations.es;
---

<section id="proceso" class="section-pad bg-paper">
  <div class="section-shell">
    <div class="max-w-5xl scroll-reveal">
      <span class="eyebrow" data-i18n="processEyebrow">{t.processEyebrow}</span>
      <h2 class="section-heading mt-7 text-[clamp(3.4rem,8vw,8rem)]" data-i18n="processTitle">{t.processTitle}</h2>
    </div>

    <div class="mt-16 grid gap-x-8 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
      {steps.map(([title, text], index) => (
        <article class="editorial-rule scroll-reveal pt-5">
          <span class="display-font text-6xl font-semibold tracking-[-0.08em] text-ink/18">
            {(index + 1).toString().padStart(2, '0')}
          </span>
          <h3 class="display-font mt-12 text-3xl font-semibold tracking-[-0.05em]" data-i18n={title}>{t[title]}</h3>
          <p class="mt-4 leading-7 text-muted" data-i18n={text}>{t[text]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
