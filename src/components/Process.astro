---
import { translations } from '../i18n/translations';

const steps = [
  ['processOneTitle', 'processOneText'],
  ['processTwoTitle', 'processTwoText'],
  ['processThreeTitle', 'processThreeText'],
  ['processFourTitle', 'processFourText'],
  ['processFiveTitle', 'processFiveText'],
  ['processSixTitle', 'processSixText'],
];

const t = translations.es;
---

<section id="proceso" class="section-pad">
  <div class="section-shell">
    <div class="max-w-3xl">
      <span class="eyebrow" data-i18n="processEyebrow">Proceso</span>
      <h2 class="section-heading mt-6 text-5xl sm:text-7xl" data-i18n="processTitle">
        Un proceso claro para decisiones de alto impacto.
      </h2>
    </div>

    <div class="mt-16 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {steps.map(([title, text], index) => (
        <article class="premium-card motion-card p-7">
          <span class="display-font text-5xl font-semibold tracking-[-0.07em] text-ink/24">
            {(index + 1).toString().padStart(2, '0')}
          </span>
          <h3 class="display-font mt-10 text-2xl font-semibold tracking-[-0.04em]" data-i18n={title}>{t[title]}</h3>
          <p class="mt-4 leading-7 text-muted" data-i18n={text}>{t[text]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
