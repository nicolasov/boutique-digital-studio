---
import WebGLPixelImage from './WebGLPixelImage.astro';

const steps = [
  {
    number: '01',
    title: 'Exploramos',
    text: 'Entendemos tu negocio, tus objetivos, tu público y el contexto actual.',
    image: '/assets/studio-cinematic.png',
  },
  {
    number: '02',
    title: 'Diseñamos',
    text: 'Definimos estructura, estética, mensajes y experiencia con criterio estratégico.',
    image: '/assets/system-abstract.png',
  },
  {
    number: '03',
    title: 'Construimos',
    text: 'Desarrollamos el sitio, sistema, contenido o automatización necesaria.',
    image: '/assets/hero-editorial.png',
  },
  {
    number: '04',
    title: 'Mejoramos',
    text: 'Revisamos, ajustamos y dejamos una base preparada para evolucionar con el tiempo.',
    image: '/assets/studio-cinematic.png',
  },
];
---

<section id="proceso" class="section-pad">
  <div class="section-shell">
    <div class="process-intro mx-auto max-w-5xl text-center scroll-reveal">
      <h2 class="process-heading section-heading text-[clamp(2.15rem,5vw,4.4rem)]">Lo hacemos en pasos claros</h2>
      <div class="process-intro-copy mt-5">
        <p>Trabajamos con un proceso claro para entender tu proyecto, detectar oportunidades y construir una solución digital alineada a tus objetivos.</p>
        <p>Creamos herramientas, experiencias y sistemas pensados para mejorar tu negocio, su presencia, comunicación y operación en el entorno digital.</p>
      </div>
    </div>

    <div class="process-step-list mt-16">
      {steps.map((step, index) => (
        <article class={`process-card process-step-row ${index % 2 === 1 ? 'is-reversed' : ''} scroll-reveal`}>
          <div class="process-step-copy">
            <span class="process-step-number">{step.number}</span>
            <h3 class="process-step-title">{step.title}</h3>
            <p class="process-step-text">{step.text}</p>
          </div>
          <WebGLPixelImage
            class="process-step-image"
            src={step.image}
            alt={`Imagen del paso ${step.number}: ${step.title}`}
            intensity={0.38}
            speed={0.92}
            scale={1.014}
            triggerOnce
          />
        </article>
      ))}
    </div>
  </div>
</section>
