---
const steps = [
  'Diagnóstico',
  'Estrategia',
  'Diseño UX/UI',
  'Desarrollo',
  'Automatización',
  'Medición y mejora',
];
---

<section id="proceso" class="py-20 sm:py-24">
  <div class="section-shell">
    <div class="max-w-2xl">
      <span class="eyebrow">Proceso</span>
      <h2 class="mt-5 text-3xl font-semibold tracking-[-0.03em] text-white sm:text-5xl">
        Un camino simple para construir con foco.
      </h2>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {steps.map((step, index) => (
        <article class="border-t border-white/12 pt-6">
          <span class="text-sm font-semibold text-[#80ffd0]">{(index + 1).toString().padStart(2, '0')}</span>
          <h3 class="mt-5 text-2xl font-semibold tracking-[-0.03em] text-white">{step}</h3>
        </article>
      ))}
    </div>
  </div>
</section>
