---
import { translations } from '../i18n/translations';

const benefits = [
  'benefitClarity',
  'benefitLeads',
  'benefitBrand',
  'benefitContact',
  'benefitAutomation',
  'benefitPresence',
  'benefitExperience',
] as const;

const t = translations.en;
---

<section id="beneficios" class="section-pad">
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
      <div class="scroll-reveal">
        <span class="eyebrow" data-i18n="benefitsEyebrow">{t.benefitsEyebrow}</span>
        <h2 class="section-heading mt-7 text-[clamp(3.4rem,8vw,8rem)]" data-i18n="benefitsTitle">
          {t.benefitsTitle}
        </h2>
      </div>
      <p class="scroll-reveal max-w-2xl text-xl leading-8 text-muted lg:ml-auto" data-i18n="benefitsIntro">
        {t.benefitsIntro}
      </p>
    </div>

    <div class="mt-14 grid gap-3 md:grid-cols-2">
      {benefits.map((key, index) => (
        <article class="benefit-item scroll-reveal">
          <span class="display-font text-3xl font-semibold tracking-[-0.07em] text-ink/28">
            {(index + 1).toString().padStart(2, '0')}
          </span>
          <p class="text-lg font-semibold leading-7 text-ink" data-i18n={key}>{t[key]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
