---
interface Props {
  size?: number;
  color?: string;
  class?: string;
}
const { size = 48, color = "currentColor", class: className = "" } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
  <rect x="4" y="10" width="40" height="28" rx="2.5" stroke={color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  <line x1="24" y1="17" x2="24" y2="31" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <line x1="17" y1="24" x2="31" y2="24" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <circle cx="24" cy="24" r="4" stroke={color} stroke-width="1.5"/>
</svg>
