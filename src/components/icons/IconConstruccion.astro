---
interface Props {
  size?: number;
  color?: string;
  class?: string;
}
const { size = 48, color = "currentColor", class: className = "" } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
  <!-- Top layer -->
  <polygon points="24,6 44,15 24,24 4,15" stroke={color} stroke-width="1.5" stroke-linejoin="round"/>
  <!-- Middle layer edges -->
  <line x1="4" y1="15" x2="4" y2="22" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <line x1="44" y1="15" x2="44" y2="22" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <line x1="4" y1="22" x2="24" y2="31" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <line x1="44" y1="22" x2="24" y2="31" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <!-- Bottom layer edges -->
  <line x1="4" y1="22" x2="4" y2="29" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <line x1="44" y1="22" x2="44" y2="29" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <line x1="4" y1="29" x2="24" y2="38" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <line x1="44" y1="29" x2="24" y2="38" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
  <!-- Connected nodes on top layer -->
  <circle cx="17" cy="15" r="3" stroke={color} stroke-width="1.5"/>
  <circle cx="31" cy="15" r="3" stroke={color} stroke-width="1.5"/>
  <line x1="20" y1="15" x2="28" y2="15" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
</svg>
