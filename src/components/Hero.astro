---
import { translations } from '../i18n/translations';

const t = translations.es;
---

<section id="top" class="relative overflow-hidden pb-20 pt-12 sm:pb-28 sm:pt-20">
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-1 lg:items-end">
      <div>
        <span class="eyebrow reveal w-fit text-base font-normal normal-case" data-i18n="heroEyebrow" data-header-trigger>{t.heroEyebrow}</span>
        <h1 class="hero-title section-heading reveal reveal-delay-1 mt-7 max-w-6xl text-[clamp(2.2rem,5.5vw,4.84rem)] text-ink">
          <span class="hero-title-line">
            <span class="hero-title-line-inner">
              <span data-i18n="heroTitlePrefix">{t.heroTitlePrefix}</span>
              <span class="hero-typewriter" data-typewriter data-typewriter-phrases="soluciones digitales|más claridad para tus clientes|sistemas que generan oportunidades">soluciones digitales</span><span class="hero-title-period">.</span>
            </span>
          </span>
        </h1>
        <div class="reveal mt-6">
          <p class="hero-loop-line text-base leading-7 sm:text-lg" data-i18n="heroText">{t.heroText}</p>
        </div>
        <div class="hero-cta reveal mt-8">
          <a
            href="https://cal.com/nicolas-oliva-velez-iehecs/hablemos-de-tu-proyecto"
            class="btn btn-primary w-full"
            data-i18n="heroPrimary"
          >
            {t.heroPrimary}
          </a>
        </div>
      </div>
    </div>

    <div class="reveal reveal-delay-3 mt-12">
      <figure class="visual-frame hero-visual relative h-[10rem] sm:h-[12rem] lg:h-[14rem]">
        <img class="image-cover" src="/assets/studio-cinematic.png" alt="Cinematic creative technology studio scene" loading="eager" />
      </figure>
    </div>

    <div class="mt-14 overflow-hidden border-y border-ink/12 py-4">
      <div class="marquee">
        <span>Sitios web premium&nbsp;&nbsp;&nbsp;·&nbsp;&nbsp;&nbsp;Diseño y dirección visual&nbsp;&nbsp;&nbsp;·&nbsp;&nbsp;&nbsp;IA y automatización&nbsp;&nbsp;&nbsp;·&nbsp;&nbsp;&nbsp;Contenido visual&nbsp;&nbsp;&nbsp;·</span>
        <span>Sitios web premium&nbsp;&nbsp;&nbsp;·&nbsp;&nbsp;&nbsp;Diseño y dirección visual&nbsp;&nbsp;&nbsp;·&nbsp;&nbsp;&nbsp;IA y automatización&nbsp;&nbsp;&nbsp;·&nbsp;&nbsp;&nbsp;Contenido visual&nbsp;&nbsp;&nbsp;·</span>
      </div>
    </div>
  </div>
</section>
