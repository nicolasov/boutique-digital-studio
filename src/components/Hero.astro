---
import { translations } from '../i18n/translations';
import HeroWebGLVisual from './HeroWebGLVisual.astro';

const t = translations.es;
---

<section id="top" class="hero-section relative overflow-hidden">
  <div class="section-shell hero-shell">
    <div class="hero-grid">
      <div class="hero-copy">
        <div class="hero-kicker reveal" data-header-trigger>
          <span class="hero-kicker-line" aria-hidden="true"></span>
          <span class="hero-kicker-lang hero-kicker-lang-es">Estudio creativo y tecnológico</span>
          <span class="hero-kicker-lang hero-kicker-lang-en">Creative Technology Studio</span>
        </div>
        <h1 class="hero-title section-heading reveal reveal-delay-1 mt-7 text-ink">
          <span class="hero-title-line">
            <span class="hero-title-line-inner">
              <span class="hero-title-prefix" data-i18n="heroTitlePrefix">{t.heroTitlePrefix}</span>
              <span class="hero-typewriter-line">
                <span class="hero-typewriter-wrap">
                  <span class="hero-typewriter" data-typewriter data-typewriter-phrases="soluciones digitales.|más claridad para tus clientes.|sistemas que generan oportunidades.">
                    <span data-typewriter-prefix>soluciones </span><span class="hero-typewriter-tail" data-typewriter-tail>digitales.</span>
                  </span>
                </span>
              </span>
            </span>
          </span>
        </h1>
        <div class="hero-subgrid">
          <div class="reveal">
            <p class="hero-loop-line text-base leading-7 sm:text-lg" data-i18n="heroText">{t.heroText}</p>
          </div>
          <div class="hero-cta reveal">
            <a
              href="https://cal.com/nicolas-oliva-velez-iehecs/hablemos-de-tu-proyecto"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary hero-primary"
              data-i18n="heroPrimary"
            >
              <span>{t.heroPrimary}</span>
            </a>
          </div>
        </div>
      </div>

      <div class="hero-visual reveal reveal-delay-3">
        <div class="hero-visual-card">
          <HeroWebGLVisual />
          <div class="hero-visual-label" aria-hidden="true">
            <span data-i18n="heroVisualLabel">{t.heroVisualLabel}</span>
            <span>01 / 01</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-marquee overflow-hidden border-y border-ink/12 py-4">
      <div class="marquee">
        <span data-i18n="marqueeText">{t.marqueeText}</span>
        <span data-i18n="marqueeText">{t.marqueeText}</span>
      </div>
    </div>
  </div>
</section>
