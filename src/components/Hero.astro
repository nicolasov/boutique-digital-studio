---
import { translations } from '../i18n/translations';

const metrics = ['heroMetricOne', 'heroMetricTwo', 'heroMetricThree'];
const t = translations.es;
---

<section class="relative overflow-hidden pb-16 pt-10 sm:pb-24 sm:pt-16">
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
      <div class="reveal flex min-h-48 flex-col justify-between border-t border-ink/14 pt-5 lg:min-h-[34rem]">
        <span class="eyebrow w-fit" data-i18n="heroEyebrow">{t.heroEyebrow}</span>
        <p class="max-w-sm text-lg leading-7 text-muted" data-i18n="heroText">{t.heroText}</p>
      </div>

      <div>
        <h1 class="section-heading reveal reveal-delay-1 text-[clamp(4.1rem,12vw,11.5rem)] text-ink">
          <span data-i18n="heroTitle">{t.heroTitle}</span>
        </h1>
        <div class="reveal reveal-delay-2 mt-8 grid gap-5 md:grid-cols-[1fr_0.56fr]">
          <figure class="visual-frame relative h-[34rem] md:h-[42rem]">
            <img class="image-cover" src="/assets/studio-cinematic.png" alt="Cinematic creative technology studio scene" loading="eager" />
            <figcaption class="absolute bottom-5 left-5 right-5 border border-white/30 bg-white/64 p-5 text-sm font-medium text-ink shadow-[0_24px_70px_rgba(17,17,17,0.12)] backdrop-blur-xl" data-i18n="heroNote">
              {t.heroNote}
            </figcaption>
          </figure>

          <aside class="grid gap-5">
            <div class="surface-grid min-h-72 border border-ink/12 bg-[#ebe6de] p-5">
              <div class="display-font text-7xl font-bold tracking-[-0.08em] text-ink">BDS</div>
              <div class="mt-16 space-y-3">
                {metrics.map((key) => (
                  <p class="border-t border-ink/14 pt-3 text-sm font-semibold uppercase tracking-[0.12em] text-muted" data-i18n={key}>
                    {t[key]}
                  </p>
                ))}
              </div>
            </div>
            <div class="relative min-h-64 overflow-hidden border border-ink/12 bg-ink p-5 text-white">
              <div class="absolute -right-20 -top-20 size-52 rounded-full bg-white/10 blur-3xl"></div>
              <p class="text-sm uppercase tracking-[0.16em] text-white/54">Motion / Systems</p>
              <div class="float-slow mt-20 h-28 border border-white/18 bg-white/10 backdrop-blur"></div>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <div class="mt-12 overflow-hidden border-y border-ink/12 py-5">
      <div class="marquee">
        <span>Creative technology · Applied AI · Digital experiences · Editorial systems ·</span>
        <span>Creative technology · Applied AI · Digital experiences · Editorial systems ·</span>
      </div>
    </div>
  </div>
</section>
