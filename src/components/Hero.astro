---
import { translations } from '../i18n/translations';

const loopItems = ['heroLoopTwo', 'heroLoopOne', 'heroLoopThree', 'heroLoopFour', 'heroLoopFive'] as const;
const t = translations.en;
---

<section id="top" class="relative overflow-hidden pb-20 pt-12 sm:pb-28 sm:pt-20">
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.78fr_0.22fr] lg:items-end">
      <div>
        <span class="eyebrow reveal w-fit" data-i18n="heroEyebrow" data-header-trigger>{t.heroEyebrow}</span>
        <h1 class="hero-title section-heading reveal reveal-delay-1 mt-7 max-w-6xl text-[clamp(3.65rem,9.2vw,9.4rem)] text-ink">
          <span data-i18n="heroTitlePrefix">{t.heroTitlePrefix}</span>
          <a href="#soluciones-digitales" class="hero-highlight">
            <span class="hero-highlight-part" data-i18n="heroTitleHighlightA">{t.heroTitleHighlightA}</span>
            <span class="hero-highlight-part" data-i18n="heroTitleHighlightB">{t.heroTitleHighlightB}</span>
          </a>
        </h1>
      </div>

      <div class="reveal reveal-delay-2 border-t border-ink/14 pt-5 lg:mb-3">
        <p class="hero-loop-line text-base leading-7 sm:text-lg" aria-live="polite">
          <span data-i18n="heroTextPrefix">{t.heroTextPrefix}</span>
          <span class="loop-word" data-hero-loop data-loop-keys={loopItems.join(',')}>{t.heroLoopTwo}</span>
        </p>
        <div class="mt-7 flex flex-wrap gap-3 lg:flex-col">
          <a
            href="https://cal.com/nicolas-oliva-velez-iehecs/hablemos-de-tu-proyecto"
            class="btn btn-primary"
            data-i18n="heroPrimary"
            data-cal-open
          >
            {t.heroPrimary}
          </a>
        </div>
      </div>
    </div>

    <div class="reveal reveal-delay-3 mt-12">
      <figure class="visual-frame relative h-[30rem] sm:h-[38rem] lg:h-[44rem]">
        <img class="image-cover" src="/assets/studio-cinematic.png" alt="Cinematic creative technology studio scene" loading="eager" />
        <figcaption class="hero-caption absolute bottom-4 left-4 right-4 p-0 text-2xl font-semibold leading-9 text-white sm:bottom-6 sm:left-6 sm:right-auto sm:max-w-2xl sm:text-3xl sm:leading-10">
          <span data-i18n="heroNote">{t.heroNote}</span>
        </figcaption>
      </figure>
    </div>

    <div class="mt-14 overflow-hidden border-y border-ink/12 py-4">
      <div class="marquee">
        <span>Creative technology · Applied AI · Digital experiences · Editorial systems ·</span>
        <span>Creative technology · Applied AI · Digital experiences · Editorial systems ·</span>
      </div>
    </div>
  </div>
</section>
