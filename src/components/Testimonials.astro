---
import { translations } from '../i18n/translations';

const quotes = ['testimonialOne', 'testimonialTwo', 'testimonialThree'];
const t = translations.es;
---

<section class="section-pad bg-paper">
  <div class="section-shell">
    <div class="grid gap-12 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <span class="eyebrow" data-i18n="testimonialsEyebrow">Confianza</span>
        <h2 class="section-heading mt-6 text-5xl sm:text-7xl" data-i18n="testimonialsTitle">
          La percepción premium también se diseña.
        </h2>
      </div>
      <div class="space-y-4">
        {quotes.map((quote, index) => (
          <article class="motion-card rounded-[28px] border border-ink/10 bg-[#f7f5f0] p-7">
            <p class="display-font text-2xl font-medium leading-tight tracking-[-0.04em] text-ink sm:text-3xl">
              “<span data-i18n={quote}>{t[quote]}</span>”
            </p>
            <div class="mt-8 flex items-center justify-between border-t border-ink/10 pt-5">
              <p class="text-sm font-semibold uppercase tracking-[0.12em] text-muted">Boutique client 0{index + 1}</p>
              <span class="text-sm text-muted">BDS</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
