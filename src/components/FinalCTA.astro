---
import { translations } from '../i18n/translations';

const t = translations.es;
---

<section id="contacto" class="section-pad">
  <div class="section-shell">
    <div class="relative overflow-hidden bg-ink px-5 py-10 text-white sm:px-8 sm:py-14 lg:px-12">
      <div class="absolute inset-0 opacity-20 surface-grid"></div>
      <div class="relative grid gap-12 lg:grid-cols-[1.25fr_0.75fr] lg:items-end">
        <div>
          <span class="eyebrow border-white/14 bg-white/10 text-white" data-i18n="ctaEyebrow">{t.ctaEyebrow}</span>
          <h2 class="section-heading mt-7 text-[clamp(3.8rem,9vw,9rem)] text-white" data-i18n="ctaTitle">
            {t.ctaTitle}
          </h2>
        </div>
        <div>
          <p class="text-xl leading-8 text-white/72" data-i18n="ctaText">{t.ctaText}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="https://cal.com/"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3.5 text-sm font-semibold text-ink transition hover:-translate-y-0.5 hover:bg-[#eeeae1]"
              data-i18n="ctaPrimary"
            >
              {t.ctaPrimary}
            </a>
            <a
              href="https://wa.me/5490000000000"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/10"
              data-i18n="ctaSecondary"
            >
              {t.ctaSecondary}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
