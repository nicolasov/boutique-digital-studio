---
import { translations } from '../i18n/translations';

const t = translations.es;
---

<section id="contacto" class="contact-section section-pad">
  <div class="section-shell">
    <div class="contact-layout">
      <div class="contact-copy">
        <span class="contact-eyebrow" data-i18n="ctaEyebrow">{t.ctaEyebrow}</span>
        <h2 class="contact-heading section-heading" data-contact-title>
          Hablemos
        </h2>
        <p class="contact-lede" data-contact-text>
          <span>Contanos qué necesitás construir, mejorar o automatizar.</span>
          <span>Puede ser una web, una identidad, contenido visual o una idea que todavía necesita forma.</span>
        </p>
      </div>
      <form class="contact-form" data-contact-form>
        <div class="contact-form-fields" data-contact-fields>
          <input type="hidden" name="_subject" value="Nueva consulta desde la web Boutique Digital Studio" />
          <input type="hidden" name="current_page" data-current-page />
          <input type="hidden" name="timestamp" data-timestamp />
          <input type="hidden" name="user_agent" data-user-agent />
          <label class="contact-honeypot" aria-hidden="true">
            <span>Website</span>
            <input name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
          </label>
          <label>
            <span data-i18n="formName">{t.formName}</span>
            <input name="name" type="text" autocomplete="name" required />
          </label>
          <label>
            <span data-i18n="formEmail">{t.formEmail}</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            <span data-i18n="formWhatsapp">{t.formWhatsapp}</span>
            <input
              name="whatsapp"
              type="tel"
              autocomplete="tel"
              inputmode="tel"
              placeholder="+54 9 11 1234 5678"
              data-contact-phone
            />
          </label>
          <label class="contact-form-message">
            <span data-i18n="formMessage">{t.formMessage}</span>
            <textarea name="message" rows="5" required></textarea>
          </label>
          <p class="contact-form-error" hidden data-contact-error data-i18n="formError" aria-live="polite">{t.formError}</p>
          <button class="btn btn-primary contact-submit" type="submit" data-contact-submit>
            <svg class="contact-submit-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
              <rect fill="none" width="100%" height="100%" pathLength="100"></rect>
            </svg>
            <span class="contact-submit-label" data-contact-submit-label>{t.formSubmit}</span>
            <span class="contact-submit-loader" aria-hidden="true"></span>
          </button>
        </div>
        <div class="contact-success" hidden data-contact-success>
          <p class="contact-success-title display-font" data-i18n="formSuccessTitle">
            {t.formSuccessTitle}
          </p>
          <p class="contact-success-text" data-i18n="formSuccessText">{t.formSuccessText}</p>
        </div>
      </form>
    </div>
  </div>
</section>
