---
import { translations } from '../i18n/translations';

const t = translations.es;
---

<section id="contacto" class="section-pad">
  <div class="section-shell">
    <div class="relative overflow-hidden px-5 py-10 text-ink sm:px-8 sm:py-14 lg:px-12">
      <div class="relative grid gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
        <div>
          <span class="eyebrow" data-i18n="ctaEyebrow">{t.ctaEyebrow}</span>
          <h2 class="section-heading mt-7 text-[clamp(2.8rem,7vw,4.2rem)] text-ink" data-i18n="ctaTitle">
            {t.ctaTitle}
          </h2>
          <p class="mt-6 max-w-2xl text-xl leading-8 text-muted" data-i18n="ctaText">{t.ctaText}</p>
        </div>
        <form class="contact-form" data-contact-form>
          <div class="contact-form-fields" data-contact-fields>
            <input type="hidden" name="_subject" value="Nueva consulta desde la web Boutique Digital Studio" />
            <input type="hidden" name="current_page" data-current-page />
            <input type="hidden" name="timestamp" data-timestamp />
            <input type="hidden" name="user_agent" data-user-agent />
            <label class="contact-honeypot" aria-hidden="true">
              <span>Website</span>
              <input name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
            </label>
            <label>
              <span data-i18n="formName">{t.formName}</span>
              <input name="name" type="text" autocomplete="name" required />
            </label>
            <label>
              <span data-i18n="formEmail">{t.formEmail}</span>
              <input name="email" type="email" autocomplete="email" required />
            </label>
            <label>
              <span data-i18n="formWhatsapp">{t.formWhatsapp}</span>
              <input
                name="whatsapp"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                placeholder="+54 9 11 1234 5678"
                data-contact-phone
              />
            </label>
            <label class="contact-form-message">
              <span data-i18n="formMessage">{t.formMessage}</span>
              <textarea name="message" rows="5" required></textarea>
            </label>
            <p class="contact-form-error" hidden data-contact-error data-i18n="formError" aria-live="polite">{t.formError}</p>
            <button class="btn btn-primary contact-submit" type="submit" data-contact-submit>
              <span class="contact-submit-label" data-i18n="formSubmit">{t.formSubmit}</span>
              <span class="contact-submit-loader" aria-hidden="true"></span>
            </button>
          </div>
          <div class="contact-success" hidden data-contact-success>
            <p class="display-font text-4xl font-semibold leading-[0.95] tracking-[-0.06em]" data-i18n="formSuccessTitle">
              {t.formSuccessTitle}
            </p>
            <p class="mt-5 text-lg leading-8 text-muted" data-i18n="formSuccessText">{t.formSuccessText}</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
