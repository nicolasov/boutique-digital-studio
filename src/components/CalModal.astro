---
import { translations } from '../i18n/translations';

const t = translations.en;
---

<div class="cal-modal" aria-hidden="true" data-cal-modal>
  <div class="cal-modal-backdrop" data-cal-close></div>
  <section class="cal-modal-panel" role="dialog" aria-modal="true" aria-labelledby="cal-modal-title">
    <div class="cal-modal-header">
      <div>
        <p class="eyebrow" data-i18n="ctaEyebrow">{t.ctaEyebrow}</p>
        <h2 id="cal-modal-title" class="display-font text-2xl font-semibold tracking-[-0.05em]" data-i18n="navCall">
          {t.navCall}
        </h2>
      </div>
      <button class="cal-modal-close" type="button" aria-label="Close scheduler" data-cal-close>
        <span aria-hidden="true"></span>
      </button>
    </div>
    <div id="cal-modal-inline" class="cal-inline" data-cal-inline></div>
  </section>
</div>
