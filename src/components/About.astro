---
import { translations } from '../i18n/translations';

const pillars = [
  ['aboutOneTitle', 'aboutOneText'],
  ['aboutTwoTitle', 'aboutTwoText'],
  ['aboutThreeTitle', 'aboutThreeText'],
];

const t = translations.en;
---

<section id="about" class="section-pad">
  <div class="section-shell">
    <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <div class="scroll-reveal">
        <span class="eyebrow" data-i18n="aboutEyebrow">{t.aboutEyebrow}</span>
        <h2 class="section-heading mt-7 text-[clamp(3.4rem,8vw,8.2rem)]" data-i18n="aboutTitle">
          {t.aboutTitle}
        </h2>
      </div>
      <div class="scroll-reveal space-y-10">
        <p class="max-w-xl text-2xl leading-9 text-ink" data-i18n="aboutText">{t.aboutText}</p>
        <div class="grid gap-4">
          {pillars.map(([title, text]) => (
            <article class="editorial-rule grid gap-4 pt-5 sm:grid-cols-[0.45fr_0.55fr]">
              <h3 class="display-font text-2xl font-semibold tracking-[-0.05em]" data-i18n={title}>{t[title]}</h3>
              <p class="leading-7 text-muted" data-i18n={text}>{t[text]}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
