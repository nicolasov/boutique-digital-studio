---
const navItems = [
  { label: 'Soluciones', href: '#soluciones' },
  { label: 'Industrias', href: '#audiencias' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Tecnologías', href: '#tecnologias' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#07090d]/78 backdrop-blur-xl">
  <div class="section-shell flex h-20 items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-3" aria-label="Boutique Digital Studio">
      <span class="grid size-9 place-items-center rounded-lg border border-white/12 bg-white/8 text-sm font-semibold text-[#80ffd0]">
        B
      </span>
      <span class="text-sm font-semibold tracking-wide text-white">Boutique Digital Studio</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a class="text-sm text-white/66 transition hover:text-white" href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="#contacto"
      class="rounded-full border border-[#80ffd0]/35 bg-[#80ffd0]/10 px-4 py-2 text-sm font-semibold text-[#dffff3] transition hover:border-[#80ffd0]/70 hover:bg-[#80ffd0]/16"
    >
      Hablemos
    </a>
  </div>
</header>
