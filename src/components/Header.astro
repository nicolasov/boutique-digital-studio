---
import { translations } from '../i18n/translations';

const primaryNav = [
  { key: 'navServices', href: '#soluciones-digitales' },
  { key: 'navWork', href: '#work' },
  { key: 'navProcess', href: '#proceso' },
];

const overlayNav = [
  { key: 'navServices', href: '#soluciones-digitales' },
  { key: 'navWork', href: '#work' },
  { key: 'navProcess', href: '#proceso' },
  { key: 'navContact', href: '#contacto' },
];

const t = translations.es;
---

<header class="site-header fixed inset-x-0 top-0 z-[100]" data-site-header>
  <div class="section-shell flex h-[76px] items-center justify-between gap-6">
    <a href="#top" class="site-brand flex items-center gap-3" aria-label="SOK">
      <span class="site-logo text-2xl font-bold text-ink">SOK</span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary navigation">
      {primaryNav.map((item) => (
        <a class="magnetic-link main-nav-link text-sm font-medium text-ink" href={item.href} data-i18n={item.key}>
          {t[item.key as keyof typeof t]}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <div class="language-mini hidden sm:inline-flex" aria-label="Language selector">
        <button type="button" data-lang-option="en">EN</button>
        <span>/</span>
        <button type="button" data-lang-option="es">ES</button>
      </div>
      <a
        href="https://cal.com/nicolas-oliva-velez-iehecs/hablemos-de-tu-proyecto"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary header-action header-call-button hidden sm:inline-flex"
      >
        <svg class="header-call-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          <rect fill="none" width="100%" height="100%" pathLength="100"></rect>
        </svg>
        <span class="calendar-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M7 3v4M17 3v4M4.5 9.5h15M6.5 5.5h11A2.5 2.5 0 0 1 20 8v10a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 18V8a2.5 2.5 0 0 1 2.5-2.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
          </svg>
        </span>
        <span class="header-call-label" data-i18n="navCall">{t.navCall}</span>
      </a>
      <button
        class="menu-button btn btn-secondary header-action"
        type="button"
        aria-expanded="false"
        aria-controls="site-menu"
        data-menu-toggle
      >
        <span class="sr-only" data-i18n="menuOpen">{t.menuOpen}</span>
        <span class="hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </div>
</header>

<div id="site-menu" class="menu-overlay fixed inset-0 z-[999] overflow-y-auto" aria-hidden="true" data-menu-overlay>
  <div class="section-shell site-menu-inner flex min-h-dvh flex-col py-4">
    <div class="site-menu-top flex items-center justify-between gap-6">
      <a href="#top" class="site-brand overlay-brand flex items-center gap-3" aria-label="SOK" data-menu-close>
        <span class="site-logo text-2xl font-bold">SOK</span>
      </a>
      <button
        class="menu-close-button btn btn-secondary"
        type="button"
        aria-label="Cerrar menú"
        data-menu-close
      >
        <span class="hamburger is-x" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>

    <div class="site-menu-content flex-1 pb-8 pt-3 sm:pt-4">
      <nav class="menu-links grid gap-0" aria-label="Menú principal">
        {overlayNav.map((item, index) => (
          <a
            href={item.href}
            class="menu-link display-font block py-3 text-[clamp(2.35rem,7.2vw,7.1rem)] font-bold leading-[0.9] tracking-[-0.064em] sm:py-4"
            style={`--stagger: ${index * 70}ms`}
            data-i18n={item.key}
            data-menu-close
          >
            {t[item.key as keyof typeof t]}
          </a>
        ))}
      </nav>

      <div class="menu-meta">
        <a
          href="https://cal.com/nicolas-oliva-velez-iehecs/hablemos-de-tu-proyecto"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary header-action header-call-button overlay-call-button"
        >
          <svg class="header-call-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            <rect fill="none" width="100%" height="100%" pathLength="100"></rect>
          </svg>
          <span class="calendar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M7 3v4M17 3v4M4.5 9.5h15M6.5 5.5h11A2.5 2.5 0 0 1 20 8v10a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 18V8a2.5 2.5 0 0 1 2.5-2.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
            </svg>
          </span>
          <span class="header-call-label" data-i18n="navCall">{t.navCall}</span>
        </a>

        <div class="overlay-language language-mini" aria-label="Language selector">
          <button type="button" data-lang-option="en">EN</button>
          <span>/</span>
          <button type="button" data-lang-option="es">ES</button>
        </div>
      </div>
    </div>
  </div>
</div>
