---
import PixelImageReveal from './PixelImageReveal.astro';
import { translations } from '../i18n/translations';

const workItems = [
  ['workOneTitle', 'workOneText', '/assets/studio-cinematic.png'],
  ['workTwoTitle', 'workTwoText', '/assets/system-abstract.png'],
  ['workThreeTitle', 'workThreeText', '/assets/hero-editorial.png'],
  ['workFourTitle', 'workFourText', '/assets/studio-cinematic.png'],
  ['workFiveTitle', 'workFiveText', '/assets/system-abstract.png'],
] as const;

const t = translations.es;
---

<section id="work" class="section-pad">
  <div class="section-shell">
    <div class="scroll-reveal">
        <h2 class="section-heading text-[clamp(3.5rem,8vw,8.4rem)]" data-i18n="workTitle">
          {t.workTitle}
        </h2>
    </div>

    <div class="mt-16 grid gap-8">
      {workItems.map(([title, text, image], index) => (
        <article class="work-row group grid gap-5 border-t border-ink/14 pt-6 md:grid-cols-[0.16fr_0.46fr_0.38fr] md:items-center">
          <span class="display-font text-7xl font-bold tracking-[-0.08em] text-ink/16 transition group-hover:text-ink">
            0{index + 1}
          </span>
          <div>
            <h3 class="display-font text-4xl font-semibold leading-[0.96] tracking-[-0.055em] sm:text-6xl" data-i18n={title}>
              {t[title]}
            </h3>
            <p class="mt-5 max-w-xl text-lg leading-7 text-muted" data-i18n={text}>{t[text]}</p>
          </div>
          <PixelImageReveal
            class="visual-frame h-72 transition duration-500 group-hover:scale-[0.985]"
            src={image}
            alt={t[title]}
            intensity={0.28}
            speed={1}
            scale={1.025}
            triggerOnce
          />
        </article>
      ))}
    </div>
  </div>
</section>
