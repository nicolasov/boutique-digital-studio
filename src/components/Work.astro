---
import { translations } from '../i18n/translations';

const workItems = [
  ['workOneTitle', 'workOneText', '/assets/studio-cinematic.png'],
  ['workTwoTitle', 'workTwoText', '/assets/system-abstract.png'],
  ['workThreeTitle', 'workThreeText', '/assets/hero-editorial.png'],
];

const t = translations.en;
---

<section id="work" class="section-pad">
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.76fr_1.24fr] lg:items-end">
      <div class="scroll-reveal">
        <span class="eyebrow" data-i18n="workEyebrow">{t.workEyebrow}</span>
        <h2 class="section-heading mt-7 text-[clamp(3.5rem,8vw,8.4rem)]" data-i18n="workTitle">
          {t.workTitle}
        </h2>
      </div>
      <p class="scroll-reveal max-w-xl text-xl leading-8 text-muted lg:ml-auto" data-i18n="workIntro">
        {t.workIntro}
      </p>
    </div>

    <div class="mt-16 grid gap-8">
      {workItems.map(([title, text, image], index) => (
        <article class="work-row group grid gap-5 border-t border-ink/14 pt-5 md:grid-cols-[0.28fr_0.36fr_0.36fr] md:items-end">
          <span class="display-font text-7xl font-bold tracking-[-0.08em] text-ink/16 transition group-hover:text-ink">
            0{index + 1}
          </span>
          <div>
            <h3 class="display-font text-4xl font-semibold leading-[0.92] tracking-[-0.06em] sm:text-6xl" data-i18n={title}>
              {t[title]}
            </h3>
            <p class="mt-5 max-w-md leading-7 text-muted" data-i18n={text}>{t[text]}</p>
          </div>
          <figure class="visual-frame h-72 transition duration-500 group-hover:scale-[0.985]">
            <img class="image-cover" src={image} alt="" loading="lazy" />
          </figure>
        </article>
      ))}
    </div>
  </div>
</section>
