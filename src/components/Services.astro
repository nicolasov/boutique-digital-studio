---
import { translations } from '../i18n/translations';

const services = [
  ['serviceWebTitle', 'serviceWebText'],
  ['serviceBrandTitle', 'serviceBrandText'],
  ['serviceAiTitle', 'serviceAiText'],
  ['serviceCroTitle', 'serviceCroText'],
  ['serviceGeoTitle', 'serviceGeoText'],
  ['serviceIntegrationsTitle', 'serviceIntegrationsText'],
];

const t = translations.en;
---

<section id="servicios" class="section-pad bg-paper">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-end">
      <div class="scroll-reveal">
        <span class="eyebrow" data-i18n="servicesEyebrow">{t.servicesEyebrow}</span>
        <h2 class="section-heading mt-7 text-5xl sm:text-7xl" data-i18n="servicesTitle">
          {t.servicesTitle}
        </h2>
      </div>
      <p class="scroll-reveal max-w-2xl text-xl leading-8 text-muted lg:ml-auto" data-i18n="servicesIntro">
        {t.servicesIntro}
      </p>
    </div>

    <div class="mt-16 divide-y divide-ink/12 border-y border-ink/12">
      {services.map(([title, text], index) => (
        <article class="group grid gap-5 py-8 transition md:grid-cols-[0.2fr_0.46fr_0.34fr] md:items-center">
          <span class="display-font text-5xl font-semibold tracking-[-0.08em] text-ink/22 transition group-hover:text-ink">
            {(index + 1).toString().padStart(2, '0')}
          </span>
          <h3 class="display-font text-4xl font-semibold leading-[0.95] tracking-[-0.06em] text-ink sm:text-6xl" data-i18n={title}>
            {t[title]}
          </h3>
          <p class="text-lg leading-8 text-muted" data-i18n={text}>{t[text]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
