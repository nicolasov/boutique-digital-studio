---
import { translations } from '../i18n/translations';

const services = [
  ['serviceWebTitle', 'serviceWebText'],
  ['serviceBrandTitle', 'serviceBrandText'],
  ['serviceAiTitle', 'serviceAiText'],
  ['serviceCroTitle', 'serviceCroText'],
  ['serviceGeoTitle', 'serviceGeoText'],
  ['serviceIntegrationsTitle', 'serviceIntegrationsText'],
];

const t = translations.es;
---

<section id="servicios" class="section-pad bg-paper">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <span class="eyebrow" data-i18n="servicesEyebrow">Servicios</span>
        <h2 class="section-heading mt-6 text-5xl sm:text-7xl" data-i18n="servicesTitle">
          Lo esencial para crear una experiencia digital premium.
        </h2>
      </div>
      <p class="max-w-2xl text-xl leading-8 text-muted lg:ml-auto" data-i18n="servicesIntro">
        Cada servicio está pensado como parte de un sistema: atraer mejor, explicar mejor, convertir mejor y operar con menos fricción.
      </p>
    </div>

    <div class="mt-16 grid gap-4">
      {services.map(([title, text], index) => (
        <article class="motion-card grid gap-6 rounded-[28px] border border-ink/10 bg-[#f7f5f0] p-6 md:grid-cols-[0.18fr_0.42fr_0.4fr] md:items-center lg:p-8">
          <span class="display-font text-4xl font-semibold tracking-[-0.06em] text-ink/26">
            {(index + 1).toString().padStart(2, '0')}
          </span>
          <h3 class="display-font text-3xl font-semibold leading-none tracking-[-0.05em] text-ink sm:text-4xl" data-i18n={title}>
            {t[title]}
          </h3>
          <p class="text-lg leading-8 text-muted" data-i18n={text}>{t[text]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
