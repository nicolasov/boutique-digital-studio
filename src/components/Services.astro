---
import { translations } from '../i18n/translations';

const services = [
  ['serviceWebTitle', 'serviceWebText'],
  ['serviceBrandTitle', 'serviceBrandText'],
  ['serviceAiTitle', 'serviceAiText'],
  ['serviceContentTitle', 'serviceContentText'],
] as const;

const t = translations.es;
---

<section id="soluciones-digitales" class="section-pad bg-paper">
  <div class="section-shell">
    {t.servicesIntro && (
      <div class="scroll-reveal max-w-5xl">
        <p class="services-intro-statement display-font font-semibold tracking-[-0.055em] text-ink" data-i18n="servicesIntro">
          {t.servicesIntro}
        </p>
      </div>
    )}

    <div class="services-accordion divide-y divide-ink/12 border-b border-ink/12">
      {services.map(([title, text]) => (
        <details class="solution-item group">
          <summary class="grid cursor-pointer list-none gap-5 py-6 md:grid-cols-[1fr_auto] md:items-center">
            <h3 class="solution-title display-font text-2xl font-semibold leading-[0.98] tracking-[-0.055em] text-ink sm:text-4xl" data-i18n={title}>
              {t[title]}
            </h3>
            <span class="solution-toggle" aria-hidden="true"></span>
          </summary>
          <div class="solution-body" data-solution-body>
            <p class="solution-copy">
              <span data-i18n={text}>{t[text]}</span>
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
