---
const technologies = [
  'Astro',
  'Next.js',
  'Vercel',
  'Headless CMS',
  'OpenAI API',
  'N8N',
  'Analytics',
  'WhatsApp integrations',
];
---

<section id="tecnologias" class="py-20 sm:py-24">
  <div class="section-shell">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-xl">
        <span class="eyebrow">Tecnologías</span>
        <h2 class="mt-5 text-3xl font-semibold tracking-[-0.03em] text-white sm:text-5xl">
          Stack moderno para experiencias veloces e inteligentes.
        </h2>
      </div>
      <p class="max-w-md leading-7 text-white/58">
        Elegimos herramientas por performance, mantenibilidad e impacto en operación.
      </p>
    </div>

    <div class="mt-12 flex flex-wrap gap-3">
      {technologies.map((tech) => (
        <span class="rounded-full border border-white/10 bg-white/[0.055] px-5 py-3 text-sm font-medium text-white/78 transition hover:border-[#80ffd0]/30 hover:text-white">
          {tech}
        </span>
      ))}
    </div>
  </div>
</section>
