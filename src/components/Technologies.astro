---
const technologies = [
  'Astro',
  'Next.js',
  'Vercel',
  'Headless CMS',
  'OpenAI API',
  'N8N',
  'Analytics',
  'WhatsApp',
  'Cal.com',
  'CRM',
];
---

<section id="tecnologias" class="section-pad bg-paper">
  <div class="section-shell">
    <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div>
        <span class="eyebrow" data-i18n="techEyebrow">Stack</span>
        <h2 class="section-heading mt-6 text-5xl sm:text-7xl" data-i18n="techTitle">
          Tecnología sobria, rápida y preparada para crecer.
        </h2>
      </div>
      <div>
        <p class="max-w-2xl text-xl leading-8 text-muted" data-i18n="techText">
          Elegimos herramientas por performance, claridad operativa y capacidad de integrarse con el negocio.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          {technologies.map((tech) => (
            <span class="rounded-full border border-ink/10 bg-[#f7f5f0] px-5 py-3 text-sm font-semibold text-ink shadow-sm transition hover:-translate-y-0.5 hover:bg-white">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
