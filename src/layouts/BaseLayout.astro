---
import '../styles/global.css';
import { translations } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = translations.es.metaTitle,
  description = translations.es.metaDescription,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f7f5f0" />
    <script is:inline>
      (() => {
        try {
          document.documentElement.classList.remove('no-js');
          document.documentElement.classList.add('js');
          const stored = window.localStorage.getItem('bds-lang');
          const langs = [window.navigator.language, ...(window.navigator.languages || [])].filter(Boolean);
          const lang = stored === 'es' || stored === 'en'
            ? stored
            : langs.some((locale) => locale.toLowerCase().startsWith('es')) ? 'es' : 'en';
          document.documentElement.lang = lang;
          document.documentElement.dataset.activeLang = lang;
        } catch {
          document.documentElement.lang = 'es';
        }
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <slot />
    <script>
      import '../i18n/client';
    </script>
  </body>
</html>
