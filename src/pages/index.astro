---
import Audiences from '../components/Audiences.astro';
import Difference from '../components/Difference.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Process from '../components/Process.astro';
import Services from '../components/Services.astro';
import Technologies from '../components/Technologies.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Boutique Digital Studio | Experiencias digitales potenciadas con IA"
  description="Landing profesional para un estudio digital boutique especializado en desarrollo web estratégico, branding, IA aplicada, automatización, UX/UI, CRO y experiencias digitales inteligentes."
>
  <Header />
  <main>
    <Hero />
    <div class="soft-divider section-shell"></div>
    <Services />
    <Audiences />
    <Difference />
    <Technologies />
    <Process />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
